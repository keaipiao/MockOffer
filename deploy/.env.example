# 复制为 deploy/.env 后按需修改（deploy/.env 不入库）。
# 统一配置入口：docker compose 用它做变量替换注入容器；本地 mvnw 经 spring-dotenv 读取本文件。
# 生产请改成强口令并通过部署平台注入。

# --- 数据库 / 对象存储（postgres、minio 容器用）---
POSTGRES_USER=mockoffer
POSTGRES_PASSWORD=mockoffer
POSTGRES_DB=mockoffer
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- 后端应用密钥 / 凭证 ---
# JWT 对称密钥（生产必须改成强随机，≥32 字节）
JWT_SECRET=

# GitHub OAuth：https://github.com/settings/developers 申请，
# 回调填 <后端地址>/login/oauth2/code/github（本地为 http://localhost:8080/login/oauth2/code/github）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 腾讯云 SES（验证码邮件，生产用；dev 走日志代发可不填）
TENCENT_SES_SECRET_ID=
TENCENT_SES_SECRET_KEY=
SES_FROM_EMAIL=
SES_TEMPLATE_ID=
